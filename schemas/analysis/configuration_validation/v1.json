{
  "$defs": {
    "ConfigurationDiagnostic": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "path",
        "severity"
      ],
      "type": "object"
    },
    "Evaluation": {
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string"
        },
        "state": {
          "type": "string"
        }
      },
      "required": [
        "state"
      ],
      "type": "object"
    },
    "RedactionMetadata": {
      "additionalProperties": false,
      "properties": {
        "operational_fields_changed": {
          "type": "boolean"
        },
        "profile": {
          "enum": [
            "public",
            "operational",
            "restricted"
          ]
        }
      },
      "required": [
        "operational_fields_changed",
        "profile"
      ],
      "type": "object"
    },
    "ResultMetadata": {
      "additionalProperties": false,
      "properties": {
        "contract_version": {
          "type": "string"
        },
        "evaluation": {
          "$ref": "#/$defs/Evaluation"
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "mode": {
          "type": "string"
        }
      },
      "required": [
        "contract_version",
        "evaluation",
        "generated_at",
        "mode"
      ],
      "type": "object"
    },
    "configurationValidationOutputMetadata": {
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "$ref": "#/$defs/ResultMetadata"
        },
        "result_digest": {
          "type": "string"
        }
      },
      "required": [
        "metadata",
        "result_digest"
      ],
      "type": "object"
    },
    "csv_record": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "data_json": {
          "type": "string"
        },
        "generated_at": {
          "type": "string"
        },
        "mode": {
          "const": "configuration_validation"
        },
        "path": {
          "type": "string"
        },
        "record_id": {
          "type": "string"
        },
        "record_type": {
          "type": "string"
        },
        "redaction": {
          "enum": [
            "public",
            "operational",
            "restricted"
          ]
        },
        "result_digest": {
          "type": "string"
        },
        "schema": {
          "const": "https://raw.githubusercontent.com/georgestarcher/dmarcgo/main/schemas/analysis/configuration_validation/v1.json#/$defs/csv_record"
        },
        "schema_version": {
          "const": "1"
        },
        "severity": {
          "type": "string"
        }
      },
      "required": [
        "schema",
        "schema_version",
        "mode",
        "generated_at",
        "result_digest",
        "redaction",
        "record_type",
        "record_id",
        "code",
        "severity",
        "path",
        "data_json"
      ],
      "type": "object"
    },
    "envelope_data": {
      "additionalProperties": false,
      "properties": {
        "diagnostics": {
          "items": {
            "$ref": "#/$defs/ConfigurationDiagnostic"
          },
          "type": "array"
        }
      },
      "required": [
        "diagnostics"
      ],
      "type": "object"
    },
    "jsonl_record": {
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "data": {
              "$ref": "#/$defs/configurationValidationOutputMetadata"
            },
            "record_type": {
              "const": "metadata"
            }
          }
        },
        {
          "properties": {
            "data": {
              "$ref": "#/$defs/ConfigurationDiagnostic"
            },
            "record_type": {
              "const": "diagnostic"
            }
          }
        }
      ],
      "properties": {
        "data": {
          "type": "object"
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "mode": {
          "const": "configuration_validation"
        },
        "record_id": {
          "minLength": 1,
          "type": "string"
        },
        "record_type": {
          "type": "string"
        },
        "redaction": {
          "enum": [
            "public",
            "operational",
            "restricted"
          ]
        },
        "result_digest": {
          "minLength": 1,
          "type": "string"
        },
        "schema": {
          "const": "https://raw.githubusercontent.com/georgestarcher/dmarcgo/main/schemas/analysis/configuration_validation/v1.json#/$defs/jsonl_record"
        },
        "schema_version": {
          "const": "1"
        }
      },
      "required": [
        "schema",
        "schema_version",
        "mode",
        "generated_at",
        "result_digest",
        "redaction",
        "record_type",
        "record_id",
        "data"
      ],
      "type": "object"
    }
  },
  "$id": "https://raw.githubusercontent.com/georgestarcher/dmarcgo/main/schemas/analysis/configuration_validation/v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "diagnostics": {
      "items": {
        "$ref": "#/$defs/ConfigurationDiagnostic"
      },
      "type": "array"
    },
    "metadata": {
      "allOf": [
        {
          "$ref": "#/$defs/ResultMetadata"
        },
        {
          "properties": {
            "mode": {
              "const": "configuration_validation"
            }
          },
          "type": "object"
        }
      ]
    },
    "mode": {
      "const": "configuration_validation"
    },
    "profile": {
      "const": "native"
    },
    "redaction": {
      "$ref": "#/$defs/RedactionMetadata"
    },
    "result_digest": {
      "minLength": 1,
      "type": "string"
    },
    "schema": {
      "const": "https://raw.githubusercontent.com/georgestarcher/dmarcgo/main/schemas/analysis/configuration_validation/v1.json"
    },
    "schema_version": {
      "const": "1"
    }
  },
  "required": [
    "diagnostics",
    "metadata",
    "mode",
    "profile",
    "redaction",
    "result_digest",
    "schema",
    "schema_version"
  ],
  "title": "dmarcgo native configuration validation output v1",
  "type": "object"
}
